# =============================================================================
# .env.production — Itinerario Bello
#
# Copie este arquivo para .env.production e preencha os valores reais.
# NUNCA commite .env.production no repositorio.
# =============================================================================

# --- Ambiente ---
APP_ENV=production
APP_DEBUG=false

# --- Banco de dados ---
POSTGRES_DB=itinerario_bello
POSTGRES_USER=bello
POSTGRES_PASSWORD=TROCAR_SENHA_FORTE_AQUI

DATABASE_URL=postgresql+psycopg://bello:TROCAR_SENHA_FORTE_AQUI@db:5432/itinerario_bello

# --- Seguranca JWT ---
# Gere com: python3 -c "from secrets import token_urlsafe; print(token_urlsafe(64))"
SECRET_KEY=TROCAR_CHAVE_SECRETA_AQUI
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Fotos ---
PHOTOS_DIR=/app/storage/photos

# --- CORS ---
# URL publica onde o frontend sera acessado (ex: http://IP_DO_SERVIDOR:8002)
CORS_ORIGINS=http://IP_DO_SERVIDOR:8002

# --- Frontend ---
FRONTEND_HTTP_PORT=8002
FRONTEND_BASE_URL=http://IP_DO_SERVIDOR:8002

# --- Cookie de autenticacao ---
# Se acessar via HTTPS use true; se HTTP puro use false
COOKIE_SECURE=false
COOKIE_DOMAIN=

# --- E-mail (recuperacao de senha) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seuemail@gmail.com
SMTP_PASSWORD=TROCAR_SENHA_APP_GMAIL
SMTP_FROM_EMAIL=seuemail@gmail.com
SMTP_FROM_NAME=Itinerario Bello
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# --- Geocodificacao reversa (opcional) ---
REVERSE_GEOCODING_ENABLED=false
REVERSE_GEOCODING_PROVIDER=nominatim
REVERSE_GEOCODING_TIMEOUT_SECONDS=3
REVERSE_GEOCODING_USER_AGENT=itinerario-bello-producao/1.0
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
