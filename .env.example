APP_ENV=local
APP_DEBUG=true

API_PORT=8000
FRONTEND_PORT=80
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,http://localhost:19006

POSTGRES_DB=itinerario_bello
POSTGRES_USER=bello
POSTGRES_PASSWORD=bello_local_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://bello:bello_local_password@db:5432/itinerario_bello
PHOTOS_DIR=/app/storage/photos

SECRET_KEY=troque-esta-chave-no-servidor
ACCESS_TOKEN_EXPIRE_MINUTES=10080

REVERSE_GEOCODING_ENABLED=false
REVERSE_GEOCODING_PROVIDER=nominatim
REVERSE_GEOCODING_TIMEOUT_SECONDS=3
REVERSE_GEOCODING_USER_AGENT=itinerario-bello-prototipo/0.1
NOMINATIM_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
